{
  "name": "@codegraphy-dev/plugin-markdown",
  "version": "1.1.10",
  "description": "CodeGraphy markdown plugin",
  "license": "MIT",
  "type": "module",
  "main": "./dist/plugin.js",
  "types": "./dist/plugin.d.ts",
  "exports": {
    ".": {
      "types": "./dist/plugin.d.ts",
      "default": "./dist/plugin.js"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && esbuild src/plugin.ts --bundle --platform=node --format=esm --target=node20 --sourcemap --outfile=dist/plugin.js",
    "lint": "eslint src",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@codegraphy-dev/plugin-api": "workspace:*"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "typescript": "^5.3.3"
  },
  "codegraphy": {
    "plugins": [
      {
        "id": "codegraphy.markdown",
        "name": "Markdown",
        "host": "core",
        "entry": "./dist/plugin.js",
        "apiVersion": "^4.0.0",
        "data": {
          "updateImpact": {
            "toggle": "reanalyze-plugin-files",
            "defaultSetting": "reanalyze-plugin-files"
          },
          "supportedExtensions": [
            "*"
          ],
          "defaultFilters": [],
          "sources": [
            {
              "id": "wikilink",
              "name": "Wikilinks",
              "description": "[[Note Name]], ![[embed]]"
            }
          ]
        }
      }
    ]
  }
}
