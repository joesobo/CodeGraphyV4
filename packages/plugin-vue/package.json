{
  "name": "@codegraphy-dev/plugin-vue",
  "version": "0.3.6",
  "description": "CodeGraphy Vue plugin",
  "license": "MIT",
  "type": "module",
  "main": "./dist/plugin.js",
  "types": "./dist/plugin.d.ts",
  "exports": {
    ".": {
      "types": "./dist/plugin.d.ts",
      "default": "./dist/plugin.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/joesobo/CodeGraphyV4.git"
  },
  "homepage": "https://github.com/joesobo/CodeGraphyV4/tree/main/packages/plugin-vue",
  "bugs": {
    "url": "https://github.com/joesobo/CodeGraphyV4/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "codegraphy",
    "codegraphy-plugin",
    "graph",
    "vue",
    "sfc"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "codegraphy.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json --emitDeclarationOnly && node ../../scripts/build-workspace-package.mjs src/plugin.ts dist/plugin.js",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@codegraphy-dev/plugin-api": "workspace:*",
    "@vue/compiler-sfc": "^3.5.35",
    "typescript": "^5.3.3"
  },
  "codegraphy": {
    "plugins": [{
      "id": "codegraphy.vue",
      "name": "Vue",
      "host": "core",
      "entry": "./dist/plugin.js",
      "apiVersion": "^4.0.0"
    }]
  }
}
