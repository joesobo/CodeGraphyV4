{
  "$schema": "../../codegraphy.schema.json",
  "id": "codegraphy.markdown",
  "name": "Markdown",
  "version": "1.0.0",
  "apiVersion": "^2.0.0",
  "tier": 1,
  "supportedExtensions": ["*"],
  "defaultFilters": [],
  "fileColors": {
    "*.md": { "color": "#7C3AED", "imagePath": "assets/markdown.svg" },
    "*.mdx": { "color": "#8B5CF6", "imagePath": "assets/markdown.svg" }
  },
  "sources": [
    { "id": "wikilink", "name": "Wikilinks", "description": "[[Note Name]], ![[embed]]" }
  ]
}
