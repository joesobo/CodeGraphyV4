{
  "$schema": "../../codegraphy.schema.json",
  "id": "codegraphy.csharp",
  "name": "C#",
  "version": "1.0.0",
  "apiVersion": "^2.0.0",
  "supportedExtensions": [
    ".cs"
  ],
  "defaultFilters": [
    "**/bin/Debug/**",
    "**/bin/Release/**",
    "**/obj/Debug/**",
    "**/obj/Release/**",
    "**/obj/project.assets.json",
    "**/obj/*.csproj.nuget.*",
    "**/.vs/**",
    "**/TestResults/**",
    "**/*.Designer.cs",
    "**/*.generated.cs",
    "**/AssemblyInfo.cs"
  ],
  "fileColors": {}
}
