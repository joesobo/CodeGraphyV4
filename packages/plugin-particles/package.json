{
  "name": "@codegraphy-dev/plugin-particles",
  "version": "0.2.5",
  "description": "CodeGraphy graph background particle effects plugin",
  "license": "MIT",
  "type": "module",
  "main": "./dist/plugin.js",
  "types": "./dist/plugin.d.ts",
  "exports": {
    ".": {
      "types": "./dist/plugin.d.ts",
      "default": "./dist/plugin.js"
    },
    "./effects": {
      "types": "./dist/effects.d.ts",
      "default": "./dist/effects.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/joesobo/CodeGraphyV4.git"
  },
  "homepage": "https://github.com/joesobo/CodeGraphyV4/tree/main/packages/plugin-particles",
  "bugs": {
    "url": "https://github.com/joesobo/CodeGraphyV4/issues"
  },
  "engines": {
    "node": ">=20.20.0 <23"
  },
  "keywords": [
    "codegraphy",
    "codegraphy-plugin",
    "graph",
    "particles",
    "background"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node build.mjs",
    "test": "vitest run",
    "lint": "eslint --no-error-on-unmatched-pattern \"src/**/*.{ts,tsx}\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@codegraphy-dev/extension-plugin-api": "workspace:*",
    "esbuild": "^0.25.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18"
  },
  "codegraphy": {
    "plugins": [
      {
        "id": "codegraphy.particles",
        "name": "Particles",
        "host": "codegraphy.extension",
        "entry": "./dist/plugin.js",
        "apiVersion": "^1.0.0"
      }
    ]
  }
}
