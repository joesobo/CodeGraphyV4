{
  "name": "@codegraphy-dev/plugin-unity",
  "version": "0.2.6",
  "description": "CodeGraphy Unity plugin",
  "license": "MIT",
  "type": "module",
  "main": "./dist/plugin.js",
  "types": "./dist/plugin.d.ts",
  "exports": {
    ".": {
      "types": "./dist/plugin.d.ts",
      "default": "./dist/plugin.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/joesobo/CodeGraphyV4.git"
  },
  "homepage": "https://github.com/joesobo/CodeGraphyV4/tree/main/packages/plugin-unity",
  "bugs": {
    "url": "https://github.com/joesobo/CodeGraphyV4/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "codegraphy",
    "codegraphy-plugin",
    "graph",
    "unity",
    "dependencies"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "assets",
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && esbuild src/plugin.ts src/extension.ts --bundle --platform=node --format=esm --target=node20 --sourcemap --outdir=dist",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" \"__tests__/**/*.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@codegraphy-dev/extension-plugin-api": "workspace:*",
    "@codegraphy-dev/plugin-api": "workspace:*"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "typescript": "^5.3.3"
  },
  "codegraphy": {
    "plugins": [
      {
        "id": "codegraphy.unity",
        "name": "Unity",
        "host": "core",
        "entry": "./dist/plugin.js",
        "apiVersion": "^4.0.0",
        "data": {
          "updateImpact": {
            "toggle": "reanalyze-plugin-files",
            "defaultSetting": "reanalyze-plugin-files"
          },
          "supportedExtensions": [
            ".unity",
            ".prefab",
            ".asset",
            ".mat",
            ".meta",
            ".asmdef",
            ".inputactions"
          ],
          "defaultFilters": [
            "**/[Ll]ibrary/**",
            "**/[Tt]emp/**",
            "**/[Oo]bj/**",
            "**/[Bb]uild/**",
            "**/[Bb]uilds/**",
            "**/[Ll]ogs/**",
            "**/[Pp]roject[Ss]ettings/**",
            "**/[Uu]ser[Ss]ettings/**",
            "**/[Mm]emory[Cc]aptures/**",
            "**/.vs/**",
            "**/.gradle/**",
            "**/.idea/**",
            "**/Assets/Packages/**",
            "**/Assets/Plugins/Editor/JetBrains/**",
            "**/ExportedObj/**",
            "**/.consulo/**",
            "**/*.meta",
            "**/*.csproj",
            "**/*.unityproj",
            "**/*.sln",
            "**/*.slnx",
            "**/*.suo",
            "**/*.user",
            "**/*.userprefs",
            "**/*.pidb",
            "**/*.booproj",
            "**/*.tmp",
            "**/*.pdb",
            "**/*.mdb",
            "**/*.pidb.meta",
            "**/*.pdb.meta",
            "**/*.mdb.meta",
            "**/*.opendb",
            "**/*.VC.db",
            "**/sysinfo.txt",
            "**/crashlytics-build.properties",
            "**/Assets/AddressableAssetsData/**/*.bin*",
            "**/Assets/StreamingAssets/aa.meta",
            "**/Assets/StreamingAssets/aa/**"
          ],
          "sources": [
            {
              "id": "unity-yaml",
              "name": "Unity YAML",
              "description": "Unity scene, prefab, and asset declarations in serialized YAML"
            },
            {
              "id": "unity-containment",
              "name": "Unity Containment",
              "description": "Scene, prefab, GameObject, and Component ownership declared by Unity YAML file IDs"
            },
            {
              "id": "script-guid",
              "name": "Script GUID",
              "description": "MonoBehaviour script references resolved through Unity .meta GUIDs"
            },
            {
              "id": "prefab-guid",
              "name": "Prefab GUID",
              "description": "Prefab instance references resolved through Unity .meta GUIDs"
            },
            {
              "id": "serialized-guid",
              "name": "Serialized GUID",
              "description": "Serialized Unity asset fields resolved through Unity .meta GUIDs"
            },
            {
              "id": "unity-event",
              "name": "Unity Event",
              "description": "Serialized Unity persistent calls from scene and prefab components to C# methods"
            }
          ]
        }
      },
      {
        "id": "codegraphy.unity.extension",
        "name": "Unity Graph View",
        "host": "codegraphy.extension",
        "entry": "./dist/extension.js",
        "apiVersion": "^1.0.0",
        "data": {
          "legendEntries": [
            {
              "id": "plugin:codegraphy.unity:file:scene",
              "label": "Unity Scene",
              "pattern": "*.unity",
              "color": "#F97316",
              "shape2D": "hexagon",
              "imagePath": "assets/unity.svg"
            },
            {
              "id": "plugin:codegraphy.unity:file:prefab",
              "label": "Unity Prefab",
              "pattern": "*.prefab",
              "color": "#8B5CF6",
              "shape2D": "hexagon",
              "imagePath": "assets/unity.svg"
            },
            {
              "id": "plugin:codegraphy.unity:file:asset",
              "label": "Unity Asset",
              "pattern": "*.asset",
              "color": "#0EA5E9",
              "shape2D": "triangle",
              "imagePath": "assets/unity.svg"
            },
            {
              "id": "plugin:codegraphy.unity:file:material",
              "label": "Unity Material",
              "pattern": "*.mat",
              "color": "#14B8A6",
              "shape2D": "circle",
              "imagePath": "assets/unity.svg"
            },
            {
              "id": "plugin:codegraphy.unity:file:assembly",
              "label": "Unity Assembly",
              "pattern": "*.asmdef",
              "color": "#64748B",
              "shape2D": "square",
              "imagePath": "assets/unity.svg"
            },
            {
              "id": "plugin:codegraphy.unity:file:input-actions",
              "label": "Unity Input Actions",
              "pattern": "*.inputactions",
              "color": "#F59E0B",
              "shape2D": "diamond",
              "imagePath": "assets/unity.svg"
            },
            {
              "id": "plugin:codegraphy.unity:symbol:game-object",
              "label": "GameObject",
              "pattern": "**",
              "color": "#0EA5E9",
              "match": {
                "nodeType": "symbol",
                "symbolKinds": [
                  "game-object"
                ],
                "symbolPluginKind": "game-object",
                "symbolSource": "codegraphy.unity",
                "symbolLanguage": "unity"
              },
              "imagePath": "assets/unity.svg"
            },
            {
              "id": "plugin:codegraphy.unity:symbol:component",
              "label": "Component",
              "pattern": "**",
              "color": "#22C55E",
              "match": {
                "nodeType": "symbol",
                "symbolKinds": [
                  "component"
                ],
                "symbolPluginKind": "component",
                "symbolSource": "codegraphy.unity",
                "symbolLanguage": "unity"
              },
              "imagePath": "assets/unity.svg"
            }
          ]
        }
      }
    ]
  }
}
