{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "pnpm-lock.yaml",
    "tsconfig*.json",
    "packages/*/tsconfig*.json",
    "packages/*/src/**/tsconfig*.json",
    "packages/*/tests/**/tsconfig*.json",
    "packages/extension/postcss.config.cjs",
    "packages/extension/tailwind.config.cjs",
    "packages/extension/vite.config.ts"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["^build", "^lint"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "test": {
      "outputs": []
    },
    "test:node": {
      "outputs": []
    },
    "test:webview": {
      "env": ["CODEGRAPHY_VITEST_WEBVIEW_GROUP"],
      "outputs": []
    },
    "test:playwright": {
      "env": [
        "CI",
        "CODEGRAPHY_CI_SOFTWARE_WEBGPU",
        "CODEGRAPHY_VSCODE_PLAYWRIGHT_GREP",
        "CODEGRAPHY_VSCODE_PLAYWRIGHT_SUITE",
        "CODEGRAPHY_VSCODE_PLAYWRIGHT_WORKERS",
        "CODEGRAPHY_VSCODE_TEST_VERSION"
      ],
      "outputs": [
        "$TURBO_ROOT$/playwright-report/**",
        "$TURBO_ROOT$/test-results/**"
      ]
    },
    "watch": {
      "cache": false,
      "persistent": true
    },
    "watch:extension": {
      "cache": false,
      "persistent": true
    },
    "watch:webview": {
      "cache": false,
      "persistent": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
