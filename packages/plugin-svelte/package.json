{
  "name": "@codegraphy-dev/plugin-svelte",
  "version": "0.2.6",
  "description": "CodeGraphy Svelte plugin",
  "license": "MIT",
  "type": "module",
  "main": "./dist/plugin.js",
  "types": "./dist/plugin.d.ts",
  "exports": {
    ".": {
      "types": "./dist/plugin.d.ts",
      "default": "./dist/plugin.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/joesobo/CodeGraphyV4.git"
  },
  "homepage": "https://github.com/joesobo/CodeGraphyV4/tree/main/packages/plugin-svelte",
  "bugs": {
    "url": "https://github.com/joesobo/CodeGraphyV4/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "codegraphy",
    "codegraphy-plugin",
    "graph",
    "svelte",
    "sfc"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "codegraphy.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json --emitDeclarationOnly && node ../../scripts/build-workspace-package.mjs src/plugin.ts dist/plugin.js --bundle-dependencies",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@codegraphy-dev/plugin-api": "workspace:*",
    "svelte": "^5.56.2",
    "typescript": "^5.3.3"
  },
  "codegraphy": {
    "plugins": [{
      "id": "codegraphy.svelte",
      "name": "Svelte",
        "host": "core",
        "entry": "./dist/plugin.js",
        "apiVersion": "^4.0.0",
        "data": {
          "updateImpact": {
            "toggle": "reanalyze-plugin-files",
            "defaultSetting": "reanalyze-plugin-files"
          }
        }
    }]
  }
}
