{
  "name": "@codegraphy-dev/plugin-unity",
  "version": "0.2.5",
  "description": "CodeGraphy Unity plugin",
  "license": "MIT",
  "type": "module",
  "main": "./dist/plugin.js",
  "types": "./dist/lifecycle.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lifecycle.d.ts",
      "default": "./dist/plugin.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/joesobo/CodeGraphyV4.git"
  },
  "homepage": "https://github.com/joesobo/CodeGraphyV4/tree/main/packages/plugin-unity",
  "bugs": {
    "url": "https://github.com/joesobo/CodeGraphyV4/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "codegraphy",
    "codegraphy-plugin",
    "graph",
    "unity",
    "dependencies"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "assets",
    "dist",
    "codegraphy.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json --emitDeclarationOnly && node ../../scripts/build-workspace-package.mjs src/lifecycle.ts dist/plugin.js --bundle-dependencies",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@codegraphy-dev/plugin-api": "workspace:*"
  },
  "codegraphy": {
    "plugins": [{
      "id": "codegraphy.unity",
      "name": "Unity",
        "host": "core",
        "entry": "./dist/plugin.js",
        "apiVersion": "^4.0.0",
        "data": {
          "updateImpact": {
            "toggle": "reanalyze-plugin-files",
            "defaultSetting": "reanalyze-plugin-files"
          },
          "interfaces": [{
            "id": "codegraphy.extension",
            "data": {
              "fileColors": {
                "*.unity": { "color": "#F97316", "shape2D": "hexagon", "imagePath": "assets/unity.svg" },
                "*.prefab": { "color": "#8B5CF6", "shape2D": "hexagon", "imagePath": "assets/unity.svg" },
                "*.asset": { "color": "#0EA5E9", "shape2D": "triangle", "imagePath": "assets/unity.svg" },
                "*.mat": { "color": "#14B8A6", "shape2D": "circle", "imagePath": "assets/unity.svg" },
                "*.asmdef": { "color": "#64748B", "shape2D": "square", "imagePath": "assets/unity.svg" },
                "*.inputactions": { "color": "#F59E0B", "shape2D": "diamond", "imagePath": "assets/unity.svg" }
              }
            }
          }]
        }
    }]
  }
}
