{
  "$schema": "../../codegraphy.schema.json",
  "id": "codegraphy.typescript",
  "name": "TypeScript/JavaScript",
  "version": "1.0.0",
  "apiVersion": "^3.0.0",
  "supportedExtensions": [
    ".ts",
    ".tsx",
    ".js",
    ".jsx",
    ".mjs",
    ".cjs"
  ],
  "defaultFilters": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/out/**",
    "**/.next/**",
    "**/.nuxt/**",
    "**/coverage/**",
    "**/.turbo/**"
  ],
  "updateImpact": {
    "toggle": "reanalyze-plugin-files",
    "defaultSetting": "reanalyze-plugin-files"
  },
  "fileColors": {}
}
