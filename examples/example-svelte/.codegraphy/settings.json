{
  "version": 1,
  "maxFiles": 1000,
  "include": [
    "**/*"
  ],
  "respectGitignore": true,
  "showOrphans": true,
  "plugins": [
    {
      "package": "@codegraphy-dev/plugin-markdown"
    },
    {
      "package": "@codegraphy-dev/plugin-typescript"
    },
    {
      "package": "@codegraphy-dev/plugin-svelte"
    }
  ],
  "pluginData": {},
  "nodeVisibility": {
    "file": true,
    "folder": false,
    "package": false,
    "symbol": false
  },
  "edgeVisibility": {
    "nests": false,
    "import": true,
    "type-import": true,
    "reexport": false,
    "call": false,
    "inherit": false,
    "reference": false,
    "test": false,
    "load": false,
    "contains": false,
    "overrides": false
  },
  "favorites": [
    "src/App.svelte"
  ],
  "bidirectionalEdges": "separate",
  "legend": [],
  "legendVisibility": {},
  "legendOrder": [],
  "filterPatterns": [
    "src/app.d.ts"
  ],
  "disabledCustomFilterPatterns": [],
  "disabledPluginFilterPatterns": [],
  "showLabels": true,
  "directionMode": "arrows",
  "directionColor": "#475569",
  "particleSpeed": 0.005,
  "particleSize": 4,
  "depthMode": false,
  "depthLimit": 1,
  "dagMode": null,
  "nodeSizeMode": "connections",
  "timeline": {
    "maxCommits": 500,
    "playbackSpeed": 1
  }
}
