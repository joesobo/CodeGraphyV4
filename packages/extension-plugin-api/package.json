{
  "name": "@codegraphy-dev/extension-plugin-api",
  "version": "1.1.0",
  "description": "Type definitions for plugins hosted by the CodeGraphy VS Code extension",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/joesobo/CodeGraphyV4.git"
  },
  "homepage": "https://github.com/joesobo/CodeGraphyV4/tree/main/packages/extension-plugin-api",
  "bugs": {
    "url": "https://github.com/joesobo/CodeGraphyV4/issues"
  },
  "keywords": [
    "codegraphy",
    "codegraphy-plugin",
    "extension-plugin-api",
    "types"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts"
    },
    "./webview": {
      "types": "./src/webview.ts"
    },
    "./graph-view": {
      "types": "./src/graphView.ts"
    },
    "./events": {
      "types": "./src/events.ts"
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "eslint src tests vitest.config.ts",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@codegraphy-dev/plugin-api": "workspace:*"
  }
}
