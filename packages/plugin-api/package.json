{
  "name": "@codegraphy-dev/plugin-api",
  "version": "6.1.0",
  "description": "Type definitions for CodeGraphy plugins",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/joesobo/CodeGraphyV4.git"
  },
  "homepage": "https://github.com/joesobo/CodeGraphyV4/tree/main/packages/plugin-api",
  "bugs": {
    "url": "https://github.com/joesobo/CodeGraphyV4/issues"
  },
  "keywords": [
    "codegraphy",
    "codegraphy-plugin",
    "plugin-api",
    "types"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts"
    },
    "./plugin": {
      "types": "./src/plugin.ts"
    },
    "./access": {
      "types": "./src/access.ts"
    },
    "./data": {
      "types": "./src/data.ts"
    },
    "./disposable": {
      "types": "./src/disposable.ts"
    },
    "./graph": {
      "types": "./src/graph.ts"
    }
  },
  "types": "src/index.ts",
  "typesVersions": {
    "*": {
      "access": [
        "src/access.ts"
      ],
      "data": [
        "src/data.ts"
      ],
      "disposable": [
        "src/disposable.ts"
      ],
      "graph": [
        "src/graph.ts"
      ],
      "plugin": [
        "src/plugin.ts"
      ]
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "eslint src tests vitest.config.ts",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT"
}
