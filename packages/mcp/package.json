{
  "name": "@codegraphy-dev/mcp",
  "version": "2.1.0",
  "description": "CodeGraphy MCP stdio server",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.22.0 <23"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "codegraphy-mcp": "./bin/codegraphy-mcp.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "test": "vitest run --config vitest.config.ts",
    "lint": "eslint src tests scripts bin",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@codegraphy-dev/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.1.12"
  }
}
