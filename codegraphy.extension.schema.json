{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://codegraphy.dev/schemas/codegraphy.extension.schema.json",
  "title": "CodeGraphy Extension Plugin Metadata",
  "type": "object",
  "required": ["fileColors"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "fileColors": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          { "type": "string" },
          {
            "type": "object",
            "required": ["color"],
            "additionalProperties": false,
            "properties": {
              "color": { "type": "string" },
              "shape2D": { "type": "string", "enum": ["circle", "square", "rectangle", "diamond", "triangle", "hexagon", "star"] },
              "imagePath": { "type": "string" }
            }
          }
        ]
      }
    }
  }
}
