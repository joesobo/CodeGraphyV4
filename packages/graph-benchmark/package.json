{
  "name": "@codegraphy-dev/graph-benchmark",
  "private": true,
  "type": "module",
  "scripts": {
    "bench:graph": "tsx src/cli/main.ts",
    "bench:graph:vault": "tsx src/obsidian/main.ts",
    "dashboard": "tsx src/dashboard/main.ts",
    "lint": "eslint src tests playwright.config.ts vitest.config.ts",
    "test": "vitest run --config vitest.config.ts",
    "test:playwright": "pnpm --filter @codegraphy-dev/extension run build:webview && playwright test --config playwright.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@codegraphy-dev/plugin-api": "workspace:*",
    "@playwright/test": "^1.58.2",
    "@webgpu/types": "^0.1.71"
  }
}
