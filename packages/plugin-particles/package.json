{
  "name": "@codegraphy-dev/plugin-particles",
  "version": "0.2.4",
  "description": "CodeGraphy graph background particle effects plugin",
  "license": "MIT",
  "type": "module",
  "main": "./dist/plugin.js",
  "types": "./dist/plugin.d.ts",
  "exports": {
    ".": {
      "types": "./dist/plugin.d.ts",
      "default": "./dist/plugin.js"
    },
    "./effects": {
      "types": "./dist/effects.d.ts",
      "default": "./dist/effects.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/joesobo/CodeGraphyV4.git"
  },
  "homepage": "https://github.com/joesobo/CodeGraphyV4/tree/main/packages/plugin-particles",
  "bugs": {
    "url": "https://github.com/joesobo/CodeGraphyV4/issues"
  },
  "engines": {
    "node": ">=20.20.0 <23"
  },
  "keywords": [
    "codegraphy",
    "codegraphy-plugin",
    "graph",
    "particles",
    "background"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "codegraphy.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json --emitDeclarationOnly && node ../../scripts/build-workspace-package.mjs src/plugin.ts dist/plugin.js --bundle-dependencies --external esbuild --vendor-package esbuild && pnpm exec esbuild src/effects.ts --bundle --platform=browser --format=esm --target=es2020 --outfile=dist/effects.js --sourcemap && pnpm exec esbuild src/webview.tsx --bundle --platform=browser --format=esm --target=es2020 --define:process.env.NODE_ENV=\\\"production\\\" --outfile=dist/webview.js --sourcemap",
    "test": "vitest run",
    "lint": "eslint --no-error-on-unmatched-pattern \"src/**/*.{ts,tsx}\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@codegraphy-dev/extension-plugin-api": "workspace:*",
    "esbuild": "^0.25.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18"
  },
  "codegraphy": {
    "plugins": [{
      "id": "codegraphy.particles",
      "name": "Particles",
      "host": "codegraphy.extension",
      "entry": "./dist/plugin.js",
      "apiVersion": "^1.0.0"
    }]
  }
}
