{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "types": ["vitest/globals", "node"],
    "paths": {
      "@codegraphy-dev/core": ["../core/src/index.ts"],
      "@codegraphy-dev/plugin-api": ["../plugin-api/src/index.ts"],
      "@codegraphy-dev/plugin-markdown": ["../plugin-markdown/src/plugin.ts"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src", "tests", "vite.config.ts", "vitest.config.ts", "vitest.includes.ts"],
  "exclude": ["tests/playwright"]
}
