{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "types": ["node", "vitest/globals", "@webgpu/types"],
    "baseUrl": ".",
    "paths": {
      "@graph-renderer": ["src/index.ts"],
      "@graph-renderer/*": ["src/*"]
    }
  },
  "include": ["src", "tests", "scripts", "vitest.config.ts"],
  "exclude": ["src/physics/wasm/assembly"]
}
