{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node", "@playwright/test"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "../../playwright.config.ts",
    "../../playwright.vscode.config.ts",
    "./**/*.ts",
    "./**/*.d.ts",
    "../playwright-vscode/**/*.ts"
  ]
}
